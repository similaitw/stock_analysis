# FinMind API Token
# 申請方式：https://finmindtrade.com/ 註冊 -> 驗證 Email -> 登入 -> 取得 Token
FINMIND_API_TOKEN=your_token_here

# 資料來源選擇 (Data Source Selection)
# 選項: AUTO, FINMIND, YFINANCE
# AUTO: 自動選擇最佳來源 (有 Token 優先用 FinMind)
# FINMIND: 強制使用 FinMind (需要 Token)
# YFINANCE: 強制使用 yfinance + twstock
DATA_SOURCE=FINMIND

# Next.js / Prisma
DATABASE_URL="file:./dev.db"
